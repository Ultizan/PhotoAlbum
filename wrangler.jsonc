{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "photoalbum",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-06-28",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "keep_vars": true
}
